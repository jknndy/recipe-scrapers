<script type="text/rocketlazyloadscript">
(function () {
  function scrollToRecipeNotes() {
    if (location.hash !== "#recipe-notes") return;

    const notes =
      document.querySelector(".wprm-recipe-notes-container") ||
      document.querySelector('div[id^="recipe-"][id$="-notes"]');

    if (!notes) return;

    const headerOffset = 120; // tweak if needed
    const y = notes.getBoundingClientRect().top + window.pageYOffset - headerOffset;

    window.scrollTo({ top: y, behavior: "smooth" });
  }

  // Run now if the page is already loaded (footer scripts often load after DOMContentLoaded)
  if (document.readyState !== "loading") {
    scrollToRecipeNotes();
  } else {
    document.addEventListener("DOMContentLoaded", scrollToRecipeNotes);
  }

  // Run when hash changes (clicking "note 1", etc.)
  window.addEventListener("hashchange", function () {
    // wait a tick so the hash is applied first
    setTimeout(scrollToRecipeNotes, 0);
  });

  // Optional: catch clicks on links that point to #recipe-notes
  document.addEventListener("click", function (e) {
    const a = e.target.closest && e.target.closest('a[href="#recipe-notes"]');
    if (!a) return;
    setTimeout(scrollToRecipeNotes, 0);
  });
})();
</script><style id="global-styles-inline-css">
